# Email delivery for the onboarding form (Resend — https://resend.com)
# Without this key the form falls back to opening the visitor's email app (mailto:).
RESEND_API_KEY=

# Optional: override the From address (domain must be verified in Resend)
# RESEND_FROM="ANSA Onboarding <onboarding@ansaia.com.au>"

# Optional: Meta (Facebook) Pixel — leave empty to keep it disabled
NEXT_PUBLIC_META_PIXEL_ID=
